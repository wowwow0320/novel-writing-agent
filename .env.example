# 프로젝트 루트에 `.env` 로 복사 후 값 입력.
# Docker Compose는 이 디렉터리의 `.env`를 자동 읽어 `${변수}` 치환에 사용합니다.
#
# 로컬 개발(uvicorn + npm run dev)만 할 때는 `backend/.env` 를 쓰면 됩니다.

# gemini 은 무료 한도(429)에 걸리기 쉬울 수 있음 → OpenAI 권장 시 openai
AI_PROVIDER=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# RAG 임베딩(OpenAI): text-embedding-3-large + dimensions=EMBEDDING_DIMENSION (DB 벡터 컬럼과 동일해야 함)
OPENAI_EMBED_MODEL=text-embedding-3-large
OPENAI_BIBLE_MODEL=gpt-5-nano

# RAG 임베딩: none | openai | gemini | ollama (openai = 위 모델·키 사용, DB pgvector 차원과 동일)
EMBEDDING_PROVIDER=openai
EMBEDDING_DIMENSION=3072
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_EMBED_MODEL=bge-m3
# OLLAMA_EMBED_BATCH_SIZE=32

RAG_RECENT_FULL_EPISODES=3
SUMMARY_MAX_CHARS=300

# Hybrid DB: PostgreSQL(원본) + Neo4j(관계 복제본)
GRAPH_ENABLED=false
NEO4J_HTTP_URL=http://127.0.0.1:7474
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
# "auto"이면 system DB에서 online/default database를 찾아 사용합니다. 특정 이름을 쓰려면 neo4j 등으로 고정하세요.
NEO4J_DATABASE=auto
# postgres | graph | manual
GRAPH_CONFLICT_POLICY=graph

# Docker 프론트(8080)·로컬 Vite(5173) 등 허용 Origin (쉼표 구분)
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
