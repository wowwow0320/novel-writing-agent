# Python 3.14에서 소스 빌드가 필요할 때만 (휠이 없는 경우):
# PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1

# --- 로컬 개발(uvicorn)용 DB ---
# Docker Compose로 db만 띄운 경우 호스트에서 접속: localhost:5433
DATABASE_URL=postgresql+asyncpg://novel:novel@localhost:5433/novel_agent

# Docker로 backend 컨테이너를 띄울 때는 compose가 DATABASE_URL을 덮어씁니다.
# API 키 등은 프로젝트 루트 `.env` 에 두고 compose가 주입합니다. (루트 `.env.example` 참고)

# 선택: CORS 허용 출처 (쉼표 구분). 미설정 시 config 기본값 사용.
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# gemini | openai (로컬 uvicorn은 backend/.env 우선)
AI_PROVIDER=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# RAG: none | openai | gemini | ollama (기본 스택 bge-m3 = 1024차원)
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSION=1024
# 임베딩 끄기: EMBEDDING_PROVIDER=none
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_EMBED_MODEL=bge-m3
# OLLAMA_EMBED_BATCH_SIZE=32
# 한글 PDF (로컬): Noto CJK 등 .otf/.ttf 경로 (Docker는 이미지에 폰트 포함)
# PDF_FONT_PATH=

RAG_RECENT_FULL_EPISODES=3
SUMMARY_MAX_CHARS=300
