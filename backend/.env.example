# Python 3.14에서 소스 빌드가 필요할 때만 (휠이 없는 경우):
# PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1

# --- 로컬 개발(uvicorn)용 DB ---
# Docker Compose로 db만 띄운 경우 호스트에서 접속: localhost:5433
DATABASE_URL=postgresql+asyncpg://novel:novel@localhost:5433/novel_agent

# Docker로 backend 컨테이너를 띄울 때는 compose가 DATABASE_URL을 덮어씁니다.
# API 키 등은 프로젝트 루트 `.env` 에 두고 compose가 주입합니다. (루트 `.env.example` 참고)

# 선택: CORS 허용 출처 (쉼표 구분). 미설정 시 config 기본값 사용.
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# gemini | openai (로컬 uvicorn은 backend/.env 우선)
AI_PROVIDER=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-large
OPENAI_BIBLE_MODEL=gpt-5-nano

# RAG: none | openai | gemini | ollama (openai = text-embedding-3-large + EMBEDDING_DIMENSION, DB vector 차원과 동일)
EMBEDDING_PROVIDER=openai
EMBEDDING_DIMENSION=3072
# 임베딩 끄기: EMBEDDING_PROVIDER=none
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_EMBED_MODEL=bge-m3
# OLLAMA_EMBED_BATCH_SIZE=32
# 한글 PDF (로컬): Noto CJK 등 .otf/.ttf 경로 (Docker는 이미지에 폰트 포함)
# PDF_FONT_PATH=

RAG_RECENT_FULL_EPISODES=3
SUMMARY_MAX_CHARS=300

# Hybrid DB: PostgreSQL(원본) + Neo4j(관계 복제본)
# 앱은 Bolt(7687)가 아니라 HTTP 트랜잭션 API(기본 7474). 비밀번호는 따옴표 없이 한 줄 권장.
GRAPH_ENABLED=false
NEO4J_HTTP_URL=http://127.0.0.1:7474
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
# "auto"이면 system DB에서 online/default database를 찾아 사용합니다. 특정 이름을 쓰려면 neo4j 등으로 고정하세요.
NEO4J_DATABASE=auto
# postgres | graph | manual
GRAPH_CONFLICT_POLICY=graph

# AI 초안(메모 오케스트·다블록). 미설정 시 config 기본값(최대 세그먼트 8, 누적 본문 상한 14000자).
# EXPAND_ORCHESTRATOR_MAX_SEGMENTS=8
# EXPAND_ACCUMULATED_PREV_MAX_CHARS=14000
